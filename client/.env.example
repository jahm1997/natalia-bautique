# ═══════════════════════════════════════════════════════════
# Natalia Boutique — Variables de Entorno (PLANTILLA)
# Copia este archivo a .env y completa los valores reales:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/natalia_boutique

# ── Autenticación JWT ────────────────────────────────────
JWT_SECRET=CAMBIAR_POR_UNA_CLAVE_SEGURA_ALEATORIA
JWT_EXPIRES_IN=7d

# ── Servidor Backend ─────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend (Vite usa el prefijo VITE_) ─────────────────
VITE_API_URL=http://localhost:4000/api

# ── Cloudinary (subida de imágenes — opcional) ───────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
